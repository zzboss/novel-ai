{
  "name": "novel-ai",
  "version": "0.1.0",
  "type": "module",
  "description": "AI小说创作桌面应用 - 面向中文网文作者的本地化AI创作工作台",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "build": "rimraf dist && npm run build:renderer && npm run build:electron && electron-builder",
    "build:renderer": "vue-tsc --noEmit && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "ai",
    "novel",
    "writing",
    "electron",
    "vue3",
    "typescript"
  ],
  "author": "AIWT Team",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@chroma-core/default-embed": "^0.1.9",
    "@electron-toolkit/utils": "^4.0.0",
    "@element-plus/icons-vue": "^2.3.2",
    "@relation-graph/vue": "^3.0.13",
    "@tiptap/core": "^2.6.0",
    "@tiptap/extension-character-count": "^2.6.0",
    "@tiptap/extension-placeholder": "^2.6.0",
    "@tiptap/pm": "^2.6.0",
    "@tiptap/starter-kit": "^2.6.0",
    "@tiptap/vue-3": "^2.6.0",
    "@vue-leaflet/vue-leaflet": "^0.10.1",
    "@xenova/transformers": "^2.17.2",
    "archiver": "^7.0.0",
    "chokidar": "^3.0.0",
    "chromadb": "^3.4.3",
    "electron-store": "^8.1.0",
    "element-plus": "^2.13.7",
    "keytar": "^7.9.0",
    "leaflet": "^1.9.4",
    "lucide-vue-next": "^1.0.0",
    "openai": "^4.7.0",
    "pinia": "^2.1.0",
    "sql.js": "^1.14.1",
    "tiktoken": "^1.0.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/marked": "^5.0.2",
    "@types/node": "^20.0.0",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.10",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "jsdom": "^29.1.1",
    "marked": "^18.0.4",
    "npm-run-all": "^4.1.0",
    "postcss": "^8.5.14",
    "rimraf": "^5.0.0",
    "sass": "^1.70.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.3.0",
    "unplugin-auto-import": "^0.18.0",
    "unplugin-vue-components": "^0.27.0",
    "vite": "^5.0.0",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.0.0",
    "wait-on": "^7.0.0"
  }
}
